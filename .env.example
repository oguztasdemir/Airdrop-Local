# AirDrop Local - Ortam Değişkenleri Şablonu

# Sunucu Yapılandırması
PORT=3000

# SMTP E-posta Sunucu Yapılandırması (Şifre Sıfırlama Kodları İçin)
# Boş bırakılırsa sistem otomatik olarak "Test Modu"na geçer ve kodları konsola yazdırır.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
